# Copy to .env.testing and adjust credentials.
# Create database: CREATE DATABASE event_booking_test;
# If you prefer SQLite (pdo_sqlite required), set:
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

APP_NAME=EventBooking
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=event_booking_test
DB_USERNAME=homestead
DB_PASSWORD=secret

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
